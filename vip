-- =============================================
--          LOGIQUE HITBOX
-- =============================================

local sizeValue = 2
local isMinimized = false

local function updateHitboxes()
    ValueLabel.Text = "Size: " .. sizeValue

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        
        pcall(function()
            local head = player.Character:FindFirstChild("Head")
            if not head then return end

            head.Size = Vector3.new(sizeValue, sizeValue, sizeValue)
            head.Transparency = 0.6
            head.CanCollide = false
            head.Massless = true
            
            -- Optionnel : évite certains bugs de physique dans quelques jeux
            if head:FindFirstChild("face") then
                head.face.Transparency = 0.6
            end
        end)
    end
end

-- Contrôles boutons
btnPlus.MouseButton1Click:Connect(function()
    if sizeValue < 50 then
        sizeValue = sizeValue + 2
        updateHitboxes()
    end
end)

btnMinus.MouseButton1Click:Connect(function()
    if sizeValue > 2 then
        sizeValue = sizeValue - 2
        updateHitboxes()
    end
end)

-- Minimiser / agrandir
MiniButton.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        MainFrame:TweenSize(UDim2.new(0, 180, 0, 35), "Out", "Quad", 0.25, true)
        btnPlus.Visible = false
        btnMinus.Visible = false
        ValueLabel.Visible = false
        MiniButton.Text = "+"
    else
        MainFrame:TweenSize(UDim2.new(0, 180, 0, 110), "Out", "Quad", 0.25, true)
        btnPlus.Visible = true
        btnMinus.Visible = true
        ValueLabel.Visible = true
        MiniButton.Text = "_"
    end
end)

-- Mise à jour en temps réel (très important pour que ça reste actif)
RunService.RenderStepped:Connect(updateHitboxes)

-- Optionnel : mise à jour quand un nouveau joueur arrive
Players.PlayerAdded:Connect(function()
    task.wait(1) -- petite attente pour que le perso spawn
    updateHitboxes()
end)

